<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reporte de Deudas</title>

    <style>
        /* Estilo general del cuerpo de la página */
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #f4f7f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }

        /* Contenedor principal para centrar el contenido */
        .container {
            max-width: 900px;
            margin: 0 auto;
            background-color: #ffffff;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        }

        /* Estilo para el título principal */
        h1 {
            color: #2c3e50;
            text-align: center;
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 15px;
            margin-bottom: 25px;
        }

        /* Contenedor para mostrar la deuda total */
        .total-container {
            background-color: #e74c3c; /* Rojo para indicar deuda */
            color: #ffffff;
            padding: 20px;
            border-radius: 8px;
            text-align: center;
            margin-bottom: 30px;
        }

            .total-container h2 {
                margin: 0;
                font-size: 1.5em;
                font-weight: 500;
            }

        /* Estilo del número total para que resalte */
        #deuda-total {
            font-size: 2.2em;
            font-weight: 700;
            display: block;
            margin-top: 5px;
        }

        /* Estilos para la tabla */
        .table-responsive {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse; /* Une los bordes de las celdas */
        }

        th, td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        /* Cabecera de la tabla */
        thead {
            background-color: #34495e;
            color: #ffffff;
        }

        /* Efecto al pasar el cursor sobre las filas */
        tbody tr:hover {
            background-color: #f5f5f5;
        }

        /* Alineación para la columna de monto */
        .monto {
            text-align: right;
            font-weight: 600;
            font-family: 'Courier New', Courier, monospace;
            color: #c0392b;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>📄 Reporte de Deudas de Clientes</h1>

        <div class="total-container">
            <h2>Deuda Total Pendiente</h2>
            <span id="deuda-total">$0.00</span>
        </div>

        <div class="table-responsive">
            <table>
                <thead>
                    <tr>
                        <th>ID Cliente</th>
                        <th>Nombre del Cliente</th>
                        <th class="monto">Monto a Deber</th>
                    </tr>
                </thead>
                <tbody id="tabla-clientes-body">
                </tbody>
            </table>
        </div>
    </div>
    <input type="hidden" id="nombre" value="@Context.Session.GetString("nombre")" />
    <script src="~/js/roles.js" asp-append-version="true"></script>
    <script>
        // --- 1. DATOS DE LOS CLIENTES ---
        // En una aplicación real, estos datos vendrían de una base de datos o una API.
        const clientesConDeuda = [
            { id: 101, nombre: 'Juan Pérez López', monto: 1500.50 },
            { id: 102, nombre: 'Ana García Méndez', monto: 875.00 },
            { id: 103, nombre: 'Carlos Sánchez Ruiz', monto: 3200.75 },
            { id: 104, nombre: 'Laura Martínez G.', monto: 450.20 },
            { id: 105, nombre: 'Luis Hernández Cruz', monto: 250.25 }
        ];

        // --- 2. LÓGICA PARA PROCESAR Y MOSTRAR LOS DATOS ---
        // Esta función se ejecuta cuando la página ha cargado completamente.
        window.onload = function() {
            const tablaBody = document.getElementById('tabla-clientes-body');
            const totalDeudaElemento = document.getElementById('deuda-total');
            let deudaTotalCalculada = 0;

            // Se recorre la lista de clientes
            clientesConDeuda.forEach(cliente => {
                // Se crea una nueva fila (<tr>) para la tabla
                const fila = document.createElement('tr');

                // Se formatea el monto como moneda (ej: $1,500.50)
                const montoFormateado = cliente.monto.toLocaleString('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                });

                // Se llena la fila con los datos del cliente
                fila.innerHTML = `
                    <td>${cliente.id}</td>
                    <td>${cliente.nombre}</td>
                    <td class="monto">${montoFormateado}</td>
                `;

                // Se añade la fila completa al cuerpo de la tabla
                tablaBody.appendChild(fila);

                // Se suma la deuda del cliente al total
                deudaTotalCalculada += cliente.monto;
            });

            // Se actualiza el "label" con el total calculado y formateado
            totalDeudaElemento.textContent = deudaTotalCalculada.toLocaleString('es-MX', {
                style: 'currency',
                currency: 'MXN'
            });
        };
    </script>

</body>
</html>