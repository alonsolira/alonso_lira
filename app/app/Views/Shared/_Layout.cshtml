<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - app</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/app.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/boxicons.scss" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admincss.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SolicitudAjuste.styles.css" asp-append-version="true" />
    <!-- Icons. Uncomment required icon fonts -->
    <link rel="stylesheet" href="~/fonts/boxicons.css" />
    <link rel="stylesheet" href="~/fonts/boxicons/boxicons.eot" />
    <link rel="stylesheet" href="~/fonts/boxicons/boxicons.svg" />
    <link rel="stylesheet" href="~/fonts/boxicons/boxicons.ttf" />
    <link rel="stylesheet" href="~/fonts/boxicons/boxicons.woff" />
    <link rel="stylesheet" href="~/fonts/boxicons/boxicons.woff2" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index"></a>
                        </li>
                        <li class="nav-item" id="Registrar_Usuario">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Registrar_Usuario">Registrar Usuarios</a>
                        </li>
                        <li class="nav-item" id="Registro_Compra">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Registro_Compra">Registro de Compra</a>
                        </li>
                        <li class="nav-item" id="Estado_Cuenta">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Estado_Cuenta">Estado de Cuenta</a>
                        </li>
                        <li class="nav-item" id="Mi_Cuenta">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Mi_Cuenta">Mi cuenta</a>
                        </li>
                        <li class="nav-item ms-auto">
                            <div id="_Nombre" class="nav-link text-dark"></div>
                        </li>
                        <li class="nav-item btnCerrar" id="_Logout">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class='bx bx-x-circle'></i>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

   
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)


    <script type="text/javascript">
        // This function runs when the page is fully loaded
        $(function() {
            // Get the path of the current page from the URL
            var currentPath = window.location.pathname;

            // Go through each navigation link in the navbar [cite: 4]
            $('.navbar-nav a.nav-link').each(function() {
                var linkPath = $(this).attr('href');

                // If the link's path matches the current page's path
                if (currentPath === linkPath) {
                    // Add the 'active' class to make it look selected
                    $(this).addClass('active');
                    // We remove 'text-dark' so our custom style is not overridden [cite: 9]
                    $(this).removeClass('text-dark');
                }
            });
        });
    </script>
</body>
</html>
